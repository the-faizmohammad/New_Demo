<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300&family=DM+Mono:wght@400;500&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
<style>
:root{--ink:#0a0a0f;--paper:#f4f1eb;--accent:#2de080;--accent2:#ff6b35;--muted:#8a8580;--border:rgba(10,10,15,0.11);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'DM Mono',monospace;background:var(--paper);color:var(--ink);overflow-x:hidden;cursor:none;}
.cursor{position:fixed;width:11px;height:11px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:multiply;}
.cursor-ring{position:fixed;width:38px;height:38px;border:1.5px solid var(--ink);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:1.1rem 3rem;background:rgba(244,241,235,0.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;text-decoration:none;color:var(--ink);letter-spacing:-0.02em;}
.nav-logo span{color:var(--accent);}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{font-size:0.7rem;text-decoration:none;color:var(--muted);letter-spacing:0.09em;text-transform:uppercase;transition:color .2s;}
.nav-links a:hover{color:var(--ink);}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1.1fr 0.9fr;align-items:center;padding:8rem 3rem 4rem;position:relative;overflow:hidden;}
.hero-bg{position:absolute;top:50%;right:-1%;transform:translateY(-50%);font-family:'Syne',sans-serif;font-size:clamp(7rem,13vw,17rem);font-weight:800;color:transparent;-webkit-text-stroke:1px rgba(10,10,15,0.055);line-height:1;pointer-events:none;user-select:none;}
.hero-left{position:relative;z-index:2;}
.eyebrow{font-size:0.68rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--muted);margin-bottom:1.4rem;display:flex;align-items:center;gap:.7rem;}
.eyebrow::before{content:'';display:block;width:1.8rem;height:1px;background:var(--accent);}
.hero-name{font-family:'Cormorant Garamond',serif;font-size:clamp(3.2rem,5.5vw,5.8rem);font-weight:300;line-height:1.04;letter-spacing:-0.02em;margin-bottom:.4rem;}
.hero-name em{font-style:italic;color:var(--accent2);}
.hero-title{font-family:'Syne',sans-serif;font-size:clamp(.85rem,1.5vw,1.15rem);font-weight:700;color:var(--muted);margin-bottom:1.8rem;line-height:1.45;max-width:34ch;}
.hero-bio{font-size:.8rem;line-height:1.85;opacity:.78;max-width:44ch;margin-bottom:2rem;}
.btn-samples{display:inline-flex;align-items:center;gap:.55rem;background:var(--ink);color:var(--paper);padding:.75rem 1.8rem;font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.09em;text-transform:uppercase;text-decoration:none;border:none;cursor:none;transition:background .25s,transform .2s;}
.btn-samples:hover{background:var(--accent);color:var(--ink);transform:translateY(-2px);}
.hero-right{position:relative;z-index:2;display:flex;flex-direction:column;align-items:flex-end;gap:1.4rem;}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);}
.stat-item{background:var(--paper);padding:1.4rem;text-align:center;}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:2.6rem;font-weight:300;line-height:1;display:block;}
.stat-num span{color:var(--accent);}
.stat-label{font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);display:block;margin-top:.35rem;}
.badge{display:flex;align-items:center;gap:.55rem;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);padding:.55rem 1rem;border:1px solid var(--border);}
.badge .dot{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.4);}}

/* MARQUEE */
.marquee-wrap{overflow:hidden;padding:1.3rem 0;background:var(--accent);border-top:1px solid rgba(10,10,15,.14);border-bottom:1px solid rgba(10,10,15,.14);}
.marquee-track{display:flex;gap:3rem;animation:marquee 26s linear infinite;white-space:nowrap;}
.mitem{font-family:'Syne',sans-serif;font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);display:flex;align-items:center;gap:.9rem;flex-shrink:0;}
.mitem::after{content:'✦';font-size:.45rem;}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* SECTIONS */
section{padding:5.5rem 3rem;}
.sec-label{font-size:.63rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:.9rem;display:flex;align-items:center;gap:.7rem;}
.sec-label::before{content:'';width:1.4rem;height:1px;background:var(--accent2);}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.8vw,3.3rem);font-weight:300;line-height:1.12;letter-spacing:-.02em;margin-bottom:2.8rem;}
.sec-title em{font-style:italic;color:var(--accent2);}

/* CONTENT SAMPLES SECTION */
.samples-section{background:var(--ink);color:var(--paper);}
.samples-section .sec-label{color:rgba(255,255,255,.38);}
.samples-section .sec-label::before{background:var(--accent);}
.samples-section .sec-title{color:var(--paper);}
.samples-section .sec-title em{color:var(--accent);}
.samples-intro{font-size:.8rem;line-height:1.85;color:rgba(255,255,255,.58);max-width:62ch;margin-bottom:2.2rem;}
.iframe-outer{border:1px solid rgba(255,255,255,.1);overflow:hidden;position:relative;}
.iframe-outer iframe{width:100%;height:680px;border:none;display:block;background:#fff;}
.iframe-note{margin-top:.9rem;font-size:.65rem;letter-spacing:.08em;color:rgba(255,255,255,.3);text-transform:uppercase;}
.iframe-note a{color:var(--accent);text-decoration:none;}
.iframe-note a:hover{text-decoration:underline;}

/* EXPERTISE */
.expertise{background:#f7f4ee;}
.exp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);}
.exp-card{background:var(--paper);padding:2.3rem 1.8rem;border-left:3px solid transparent;transition:border-color .3s,background .3s;}
.exp-card:hover{border-left-color:var(--accent);background:#fff;}
.exp-icon{font-size:1.7rem;margin-bottom:1.1rem;}
.exp-name{font-family:'Syne',sans-serif;font-size:.92rem;font-weight:700;margin-bottom:.6rem;}
.exp-desc{font-size:.73rem;line-height:1.72;color:var(--muted);}
.exp-tags{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.9rem;}
.etag{font-size:.58rem;letter-spacing:.07em;text-transform:uppercase;padding:.22rem .55rem;border:1px solid var(--border);color:var(--muted);transition:all .2s;}
.exp-card:hover .etag{border-color:var(--ink);color:var(--ink);}

/* PROJECTS */
.projects-sec{background:var(--paper);}
.proj-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);}
.proj-card{background:var(--paper);overflow:hidden;display:flex;flex-direction:column;transition:transform .3s,box-shadow .3s;}
.proj-card:hover{transform:translateY(-3px);box-shadow:0 10px 36px rgba(0,0,0,.1);}
.proj-card.feat{grid-column:span 2;background:var(--ink);color:var(--paper);display:grid;grid-template-columns:1fr 1fr;gap:0;}
.proj-img{width:100%;height:210px;object-fit:cover;object-position:top;display:block;border-bottom:1px solid var(--border);}
.proj-card.feat .proj-img{height:100%;min-height:290px;border-bottom:none;border-right:1px solid rgba(255,255,255,.08);}
.proj-body{padding:1.8rem;flex:1;display:flex;flex-direction:column;}
.proj-badge{display:inline-block;font-size:.58rem;letter-spacing:.11em;text-transform:uppercase;padding:.28rem .65rem;background:var(--accent);color:var(--ink);margin-bottom:.9rem;align-self:flex-start;}
.proj-name{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:700;margin-bottom:.65rem;letter-spacing:-.01em;}
.proj-card.feat .proj-name{font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:300;color:var(--paper);}
.proj-desc{font-size:.75rem;line-height:1.75;color:var(--muted);flex:1;}
.proj-card.feat .proj-desc{color:rgba(255,255,255,.58);}
.proj-meta{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:1rem;}
.chip{font-size:.6rem;letter-spacing:.06em;text-transform:uppercase;padding:.25rem .6rem;border:1px solid var(--border);color:var(--muted);}
.proj-card.feat .chip{border-color:rgba(255,255,255,.14);color:rgba(255,255,255,.42);}
.proj-link{display:inline-flex;align-items:center;gap:.35rem;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink);text-decoration:none;margin-top:1.1rem;border-bottom:1px solid var(--ink);padding-bottom:2px;align-self:flex-start;transition:color .2s,border-color .2s;}
.proj-link:hover{color:var(--accent2);border-color:var(--accent2);}
.proj-card.feat .proj-link{color:var(--accent);border-color:var(--accent);}

/* ARTICULATE */
.articulate-sec{background:#f7f4ee;}
.art-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.8rem;}
.art-card{border:1px solid var(--border);overflow:hidden;transition:box-shadow .3s;}
.art-card:hover{box-shadow:0 8px 28px rgba(0,0,0,.09);}
.art-img{width:100%;height:240px;object-fit:cover;object-position:top;display:block;}
.art-body{padding:1.4rem;}
.art-sub{font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent2);margin-bottom:.4rem;}
.art-name{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:.45rem;}
.art-desc{font-size:.73rem;line-height:1.7;color:var(--muted);}

/* ACCESSIBILITY */
.a11y-sec{background:var(--ink);color:var(--paper);}
.a11y-sec .sec-label{color:rgba(255,255,255,.38);}
.a11y-sec .sec-label::before{background:var(--accent2);}
.a11y-sec .sec-title{color:var(--paper);}
.a11y-sec .sec-title em{color:var(--accent);}
.a11y-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:4rem;align-items:start;}
.a11y-intro{font-size:.8rem;line-height:1.88;color:rgba(255,255,255,.6);}
.a11y-intro strong{color:var(--accent);font-weight:500;}
.checks{display:flex;flex-direction:column;gap:.75rem;}
.check{display:flex;align-items:flex-start;gap:.9rem;padding:1.1rem 1.4rem;border:1px solid rgba(255,255,255,.08);transition:border-color .3s;}
.check:hover{border-color:var(--accent);}
.chk-icon{flex-shrink:0;width:34px;height:34px;background:rgba(45,224,128,.08);border:1px solid rgba(45,224,128,.18);display:flex;align-items:center;justify-content:center;font-size:.85rem;}
.chk-name{font-family:'Syne',sans-serif;font-size:.82rem;font-weight:700;margin-bottom:.25rem;}
.chk-desc{font-size:.7rem;line-height:1.62;color:rgba(255,255,255,.42);}

/* TIMELINE */
.exp-sec{background:#f7f4ee;}
.timeline{position:relative;padding-left:2rem;}
.timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:var(--border);}
.t-item{position:relative;padding-bottom:2.8rem;padding-left:2.4rem;opacity:0;transform:translateX(-18px);transition:opacity .6s ease,transform .6s ease;}
.t-item.visible{opacity:1;transform:translateX(0);}
.t-dot{position:absolute;left:-2.5rem;top:.35rem;width:11px;height:11px;border-radius:50%;background:var(--paper);border:2px solid var(--ink);transition:background .3s;}
.t-item:hover .t-dot{background:var(--accent);border-color:var(--accent);}
.t-period{font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.35rem;}
.t-role{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:700;margin-bottom:.18rem;}
.t-org{font-family:'Cormorant Garamond',serif;font-size:.95rem;font-style:italic;color:var(--accent2);margin-bottom:.85rem;}
.t-bullets{list-style:none;display:flex;flex-direction:column;gap:.45rem;}
.t-bullets li{font-size:.75rem;line-height:1.72;padding-left:.9rem;position:relative;opacity:.82;}
.t-bullets li::before{content:'→';position:absolute;left:0;color:var(--accent);font-size:.68rem;}

/* TOOLS */
.tools-sec{background:var(--paper);padding:3rem 3rem 5rem;}
.tools-wrap{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:1.8rem;}
.tool{display:inline-flex;align-items:center;gap:.38rem;font-size:.65rem;letter-spacing:.06em;text-transform:uppercase;padding:.4rem .9rem;border:1px solid var(--border);color:var(--muted);background:#fff;transition:all .2s;}
.tool:hover{background:var(--ink);color:var(--paper);border-color:var(--ink);}
.tdot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}

/* CONTACT */
.contact-sec{background:var(--ink);color:var(--paper);padding:5.5rem 3rem;}
.contact-sec .sec-label{color:rgba(255,255,255,.38);}
.contact-sec .sec-label::before{background:var(--accent);}
.contact-sec .sec-title{color:var(--paper);}
.contact-sec .sec-title em{color:var(--accent);}
.contact-links{display:flex;flex-direction:column;gap:.7rem;max-width:520px;}
.clink{display:flex;align-items:center;gap:1rem;font-size:.76rem;letter-spacing:.04em;color:var(--paper);text-decoration:none;padding:.9rem 1.2rem;border:1px solid rgba(255,255,255,.1);transition:border-color .2s,background .2s;}
.clink:hover{border-color:var(--accent);background:rgba(45,224,128,.07);}
.clink-icon{font-size:.95rem;flex-shrink:0;}

footer{background:#060608;color:rgba(255,255,255,.28);padding:1.8rem 3rem;display:flex;align-items:center;justify-content:space-between;font-size:.65rem;letter-spacing:.08em;text-transform:uppercase;}
footer a{color:rgba(255,255,255,.45);text-decoration:none;}
footer a:hover{color:var(--accent);}

.fade-up{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease;}
.fade-up.visible{opacity:1;transform:translateY(0);}

@media(max-width:900px){
  .hero{grid-template-columns:1fr;padding:7rem 1.5rem 3rem;}
  .hero-right{align-items:flex-start;margin-top:2rem;}
  .exp-grid{grid-template-columns:1fr 1fr;}
  .proj-grid{grid-template-columns:1fr;}
  .proj-card.feat{grid-column:span 1;grid-template-columns:1fr;}
  .proj-card.feat .proj-img{height:200px;min-height:unset;border-right:none;border-bottom:1px solid rgba(255,255,255,.08);}
  .art-grid{grid-template-columns:1fr;}
  .a11y-grid{grid-template-columns:1fr;gap:2rem;}
  nav{padding:1rem 1.5rem;}
  section{padding:3.5rem 1.5rem;}
  .nav-links{display:none;}
}
@media(max-width:580px){
  .exp-grid{grid-template-columns:1fr;}
  .stat-grid{grid-template-columns:1fr 1fr;}
}
</style>
</head>
